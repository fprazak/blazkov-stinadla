rules_version = '2';

// =====================================================================
// OTEVŘENÁ PRAVIDLA — kdokoli může číst i zapisovat VŠECHNA data.
// Žádné omezení, žádné přihlášení není potřeba.
//
// ⚠️ POZOR: kdokoli s odkazem na projekt může data číst, měnit i smazat.
// Vhodné pro jednorázovou hru. Pro ostrý/dlouhodobý provoz nahraď
// pravidly, která vyžadují auth a omezují zápis.
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
